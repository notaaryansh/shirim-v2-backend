OPENAI_API_KEY=sk-...
# Optional — raises GitHub API rate limit from 60/hr to 5000/hr
GITHUB_TOKEN=
# Optional — override default port 8001
SHIRIM_BACKEND_PORT=8001

# --- Supabase (reuse the shirim project's credentials) ---
SUPABASE_PROJECT_ID=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_API_KEY=
SUPABASE_SECRET_KEY=
JWT_SECRET_KEY=
# When DEV_BYPASS_AUTH=true, protected routes resolve to the real Supabase
# user matching DEV_USER_EMAIL (via the admin client). Leave both unset in
# production.
DEV_BYPASS_AUTH=false
DEV_USER_EMAIL=
